SITE_BASE_URL=https://example.com
DATABASE_PATH=data/calmtechrss.sqlite3
SOURCES_PATH=config/sources.yml
OUTPUT_DIR=site

# Optional OpenAI-compatible chat completions API.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional embedding model. If sentence-transformers/model loading is unavailable,
# the app falls back to deterministic local hashing embeddings.
EMBEDDING_MODEL=intfloat/multilingual-e5-small

