<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ issue_date }} 科技简报</title>
  <style>
    :root {
      color-scheme: light;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: #202124;
      background: #f7f7f4;
    }
    body {
      margin: 0;
      line-height: 1.65;
    }
    main {
      max-width: 820px;
      margin: 0 auto;
      padding: 48px 20px 72px;
    }
    header {
      border-bottom: 1px solid #d8d8d2;
      margin-bottom: 32px;
      padding-bottom: 24px;
    }
    h1 {
      margin: 0 0 8px;
      font-size: 2rem;
      font-weight: 650;
      letter-spacing: 0;
    }
    .meta {
      color: #64645f;
      font-size: 0.95rem;
    }
    article {
      padding: 24px 0;
      border-bottom: 1px solid #e1e1dc;
    }
    h2 {
      margin: 0 0 10px;
      font-size: 1.3rem;
      line-height: 1.35;
      letter-spacing: 0;
    }
    p {
      margin: 0 0 14px;
    }
    .uncertainty {
      color: #6f5c22;
      font-size: 0.95rem;
    }
    ul {
      margin: 8px 0 0;
      padding-left: 20px;
    }
    a {
      color: #225ea8;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    footer {
      color: #64645f;
      margin-top: 32px;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <main>
    <header>
      <h1>{{ issue_date }} 科技简报</h1>
      <div class="meta">平静、客观、克制的科技日报。生成时间：{{ generated_at.strftime("%Y-%m-%d %H:%M UTC") }}</div>
    </header>
    {% if events %}
      {% for event, rewrite in events %}
        <article>
          <h2>{{ rewrite.title }}</h2>
          <p>{{ rewrite.summary }}</p>
          {% if rewrite.uncertainty %}
            <p class="uncertainty">{{ rewrite.uncertainty }}</p>
          {% endif %}
          <ul>
            {% for source in rewrite.sources %}
              <li><a href="{{ source.url }}">{{ source.name }}</a></li>
            {% endfor %}
          </ul>
        </article>
      {% endfor %}
    {% else %}
      <p>最近窗口内没有足够有效的 RSS 内容生成简报。</p>
    {% endif %}
    <footer>
      <a href="{{ site_base_url }}/feed.xml">RSS Feed</a>
    </footer>
  </main>
</body>
</html>

